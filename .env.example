# DeuceLeague Admin Environment Configuration
# ============================================
#
# Copy this file to .env and update with your values:
#   cp .env.example .env
#
# IMPORTANT: .env files are git-ignored. Never commit secrets!

# Backend API base URL
# - Local: http://localhost:3000
# - Staging: https://staging-api.deuceleague.com
# - Production: https://api.deuceleague.com
VITE_API_BASE_URL=http://localhost:3000

# Authentication service URL (better-auth endpoint)
# - Local: http://localhost:3000
# - Production: https://api.deuceleague.com
VITE_AUTH_URL=http://localhost:3000
